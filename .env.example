# CalendarAdvanced runtime
CALENDAR_ADDR=:8080
CALENDAR_HOST_PORT=8090
CALENDAR_DATA_DIR=/data
CALENDAR_MIGRATIONS_DIR=/app/migrations
CALENDAR_SEEDS_DIR=/app/seeds
CALENDAR_STATIC_DIR=/app/web
CALENDAR_PUBLIC_URL=http://localhost:8090
# Use true when CalendarAdvanced is served through HTTPS.
CALENDAR_COOKIE_SECURE=false
CALENDAR_SESSION_DAYS=14
CALENDAR_UPDATE_CHECK_URL=https://api.github.com/repos/ichwars/CalendarAdvanced/releases/latest

# Recommended for stable encrypted integration and 2FA secret storage.
# If empty, CalendarAdvanced creates /data/calendaradvanced.key on first start.
# Generate for production: openssl rand -base64 32
CALENDAR_TOKEN_ENCRYPTION_KEY=

# Optional SMTP for password reset e-mail.
CALENDAR_SMTP_HOST=
CALENDAR_SMTP_PORT=587
CALENDAR_SMTP_USER=
CALENDAR_SMTP_PASSWORD=
CALENDAR_SMTP_FROM=
CALENDAR_SMTP_STARTTLS=true

# Development only: return password reset token in API response when SMTP is disabled.
CALENDAR_LOCAL_RESET_TOKENS=false
